Select S.SaleID, SaleDate, Tax, Shipping, TotalItemAmt, Round((TotalItemAmt + Tax + Shipping),2) as SaleTotal
From Sale S join (Select SaleID, Sum(saleprice * quantity) as totalItemAmt from SaleItem group by saleid) Sumt
on S.SaleID = Sumt.SaleID where Tax <> 0 and Month(saledate) = 2 and Year(saledate)=2015

